<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pesquisar Produtos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <a href="/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
      <a href="/customer/supermarkets" class="btn btn-outline-dark">Supermercados</a>
    </div>
    <a href="/customer/cart" class="btn btn-outline-primary"><i class="bi bi-cart3"></i> Carrinho (<%= cartCount %>)</a>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-search"></i> Pesquisar Produtos</h1>

  <!-- Filters -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/customer/products" class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Nome</label>
          <input type="text" name="name" class="form-control" value="<%= filters && filters.name ? filters.name : '' %>" placeholder="Pesquisar produto...">
        </div>
        <div class="col-md-2">
          <label class="form-label">Categoria</label>
          <select name="category" class="form-select">
            <option value="">Todas</option>
            <% if (categories) categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= filters && filters.category === cat ? 'selected' : '' %>><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Supermercado</label>
          <select name="supermarket" class="form-select">
            <option value="">Todos</option>
            <% if (supermarkets) supermarkets.forEach(sm => { %>
              <option value="<%= sm._id %>" <%= filters && filters.supermarket === String(sm._id) ? 'selected' : '' %>><%= sm.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Ordenar</label>
          <select name="sort" class="form-select">
            <option value="" <%= !filters || !filters.sort ? 'selected' : '' %>>Relevância</option>
            <option value="priceAsc" <%= filters && filters.sort === 'priceAsc' ? 'selected' : '' %>>Preço ↑</option>
            <option value="priceDesc" <%= filters && filters.sort === 'priceDesc' ? 'selected' : '' %>>Preço ↓</option>
            <option value="az" <%= filters && filters.sort === 'az' ? 'selected' : '' %>>A–Z</option>
            <option value="za" <%= filters && filters.sort === 'za' ? 'selected' : '' %>>Z–A</option>
          </select>
        </div>
        <div class="col-md-1 d-grid">
          <button type="submit" class="btn btn-dark"><i class="bi bi-search"></i></button>
        </div>
      </form>
    </div>
  </div>

  <% if (!products || products.length === 0) { %>
    <div class="alert alert-info"><i class="bi bi-info-circle"></i> Nenhum produto encontrado.</div>
  <% } else { %>
    <p class="text-muted mb-3"><%= products.length %> produto(s) encontrado(s)</p>
    <div class="row g-3">
      <% products.forEach(product => { %>
        <div class="col-md-4 col-lg-3">
          <div class="card h-100 shadow-sm">
            <% if (product.image) { %>
              <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>" style="height: 160px; object-fit: cover;">
            <% } else { %>
              <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 160px;">
                <i class="bi bi-box-seam fs-1 text-muted"></i>
              </div>
            <% } %>
            <div class="card-body d-flex flex-column">
              <h6 class="card-title mb-1"><%= product.name %></h6>
              <span class="badge bg-secondary mb-1" style="width: fit-content;"><%= product.category %></span>
              <% if (product.supermarket) { %>
                <small class="text-muted mb-1"><i class="bi bi-shop"></i>
                  <a href="/customer/supermarkets/<%= product.supermarket._id %>"><%= product.supermarket.name %></a>
                </small>
              <% } %>
              <div class="mt-auto pt-2">
                <p class="fw-bold mb-1"><%= product.price.toFixed(2) %> €</p>
                <p class="small text-muted mb-2">Stock: <%= product.stock %></p>
                <% if (product.stock > 0) { %>
                  <form method="POST" action="/customer/cart/add" class="d-flex gap-1 mb-1">
                    <input type="hidden" name="productId" value="<%= product._id %>">
                    <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>" class="form-control form-control-sm" style="width: 55px;">
                    <button type="submit" class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-cart-plus"></i></button>
                  </form>
                  <a href="/customer/compare/<%= encodeURIComponent(product.name) %>" class="btn btn-outline-info btn-sm w-100">
                    <i class="bi bi-bar-chart"></i> Comparar
                  </a>
                <% } else { %>
                  <button class="btn btn-secondary btn-sm w-100" disabled>Sem stock</button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</body>
</html>