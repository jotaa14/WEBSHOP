<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Avaliar Encomenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="d-flex justify-content-between align-items-center mb-4">
    <a href="/customer/orders" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Voltar às encomendas</a>
    <a href="/customer/cart" class="btn btn-outline-primary"><i class="bi bi-cart3"></i> Carrinho (<%= cartCount %>)</a>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-star"></i> Avaliar Encomenda</h1>

  <div class="card shadow-sm mb-4">
    <div class="card-header"><strong>Detalhes da encomenda</strong></div>
    <div class="card-body">
      <p class="mb-1"><strong>ID:</strong> <code><%= order._id %></code></p>
      <p class="mb-1"><strong>Supermercado:</strong> <%= order.supermarket ? order.supermarket.name : 'N/A' %></p>
      <% if (order.courier) { %>
        <p class="mb-1"><strong>Estafeta:</strong> <%= order.courier.name %></p>
      <% } %>
      <p class="mb-1"><strong>Total:</strong> <%= order.total.toFixed(2) %> €</p>
      <p class="mb-0"><strong>Data:</strong> <%= new Date(order.createdAt).toLocaleString('pt-PT') %></p>
    </div>
  </div>

  <form method="POST" action="/customer/orders/<%= order._id %>/review">
    <% if (order.supermarket) { %>
      <div class="card shadow-sm mb-4">
        <div class="card-header"><strong><i class="bi bi-shop"></i> Avaliação do Supermercado</strong></div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label">Classificação (1–5)</label>
            <select name="supermarketRating" class="form-select" style="width: 120px;">
              <option value="">Sem avaliação</option>
              <% for (let i = 1; i <= 5; i++) { %>
                <option value="<%= i %>" <%= existingReview && existingReview.supermarketRating === i ? 'selected' : '' %>><%= i %> ★</option>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Comentário (opcional)</label>
            <textarea name="supermarketComment" class="form-control" rows="3"><%= existingReview ? existingReview.supermarketComment || '' : '' %></textarea>
          </div>
        </div>
      </div>
    <% } %>

    <% if (order.courier) { %>
      <div class="card shadow-sm mb-4">
        <div class="card-header"><strong><i class="bi bi-bicycle"></i> Avaliação do Estafeta</strong></div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label">Classificação (1–5)</label>
            <select name="courierRating" class="form-select" style="width: 120px;">
              <option value="">Sem avaliação</option>
              <% for (let i = 1; i <= 5; i++) { %>
                <option value="<%= i %>" <%= existingReview && existingReview.courierRating === i ? 'selected' : '' %>><%= i %> ★</option>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Comentário (opcional)</label>
            <textarea name="courierComment" class="form-control" rows="3"><%= existingReview ? existingReview.courierComment || '' : '' %></textarea>
          </div>
        </div>
      </div>
    <% } %>

    <button type="submit" class="btn btn-success btn-lg">
      <i class="bi bi-send"></i> <%= existingReview ? 'Atualizar Avaliação' : 'Enviar Avaliação' %>
    </button>
  </form>
</body>
</html>
