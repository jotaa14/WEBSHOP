<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Avaliações — <%= supermarket.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <a href="/customer/supermarkets/<%= supermarket._id %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Voltar ao Supermercado</a>
    </div>
    <a href="/customer/cart" class="btn btn-outline-primary">
      <i class="bi bi-cart3"></i> Carrinho (<%= cartCount %>)
    </a>
  </nav>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h1 class="h3 mb-1"><i class="bi bi-star"></i> Avaliações de <%= supermarket.name %></h1>
      <p class="text-muted mb-0">O que os outros clientes dizem sobre este supermercado.</p>
      <% if (supermarket.averageRating > 0) { %>
        <div class="mt-2">
          <span class="fs-4 text-warning">
            <% for (let i = 1; i <= 5; i++) { %>
              <i class="bi <%= i <= Math.round(supermarket.averageRating) ? 'bi-star-fill' : 'bi-star' %>"></i>
            <% } %>
          </span>
          <span class="ms-2 fw-bold"><%= supermarket.averageRating.toFixed(1) %> / 5</span>
          <span class="text-muted">(<%= supermarket.totalRatings %> avaliações)</span>
        </div>
      <% } %>
    </div>
  </div>

  <% if (!reviews || reviews.length === 0) { %>
    <div class="alert alert-info">Ainda não existem avaliações para este supermercado.</div>
  <% } else { %>
    <div class="row g-3">
      <% reviews.forEach(review => { %>
        <% if (review.supermarketRating) { %>
          <div class="col-12">
            <div class="card shadow-sm">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <div class="text-warning">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <i class="bi <%= i <= review.supermarketRating ? 'bi-star-fill' : 'bi-star' %>"></i>
                    <% } %>
                  </div>
                  <small class="text-muted"><%= new Date(review.createdAt).toLocaleDateString('pt-PT') %></small>
                </div>
                <p class="mb-1"><strong><%= review.customer ? review.customer.name : 'Cliente Anónimo' %></strong></p>
                <p class="card-text"><%= review.supermarketComment || 'Sem comentário.' %></p>
              </div>
            </div>
          </div>
        <% } %>
      <% }) %>
    </div>
  <% } %>
</body>
</html>
