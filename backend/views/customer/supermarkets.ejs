<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Supermercados</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <a href="/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
      <a href="/customer/products" class="btn btn-outline-info">Pesquisar produtos</a>
    </div>
    <a href="/customer/cart" class="btn btn-outline-primary"><i class="bi bi-cart3"></i> Carrinho (<%= cartCount %>)</a>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-shop"></i> Supermercados</h1>

  <!-- Filters -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/customer/supermarkets" class="row g-2 align-items-end">
        <div class="col-md-4">
          <label class="form-label">Nome</label>
          <input type="text" name="name" class="form-control" value="<%= filters && filters.name ? filters.name : '' %>" placeholder="Pesquisar...">
        </div>
        <div class="col-md-2">
          <label class="form-label">Ordenar</label>
          <select name="sort" class="form-select">
            <option value="relevance" <%= filters && filters.sort === 'relevance' ? 'selected' : '' %>>Relevância</option>
            <option value="az" <%= filters && filters.sort === 'az' ? 'selected' : '' %>>A–Z</option>
            <option value="za" <%= filters && filters.sort === 'za' ? 'selected' : '' %>>Z–A</option>
            <option value="rating" <%= filters && filters.sort === 'rating' ? 'selected' : '' %>>Avaliação</option>
          </select>
        </div>
        <div class="col-md-2">
          <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" name="openNow" value="true" id="openNow"
              <%= filters && filters.openNow === 'true' ? 'checked' : '' %>>
            <label class="form-check-label" for="openNow">Aberto agora</label>
          </div>
        </div>
        <div class="col-md-1 d-grid">
          <button type="submit" class="btn btn-dark"><i class="bi bi-search"></i></button>
        </div>
      </form>
    </div>
  </div>

  <% if (!supermarkets || supermarkets.length === 0) { %>
    <div class="alert alert-info"><i class="bi bi-info-circle"></i> Nenhum supermercado encontrado.</div>
  <% } else { %>
    <div class="row g-3">
      <% supermarkets.forEach(sm => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= sm.name %></h5>
              <p class="text-muted small mb-1"><i class="bi bi-geo-alt"></i> <%= sm.city || '' %>, <%= sm.district %></p>
              <p class="small mb-1">
                <i class="bi bi-clock"></i>
                <%= String(sm.openingHour || 0).padStart(2, '0') %>:<%= String(sm.openingMinute || 0).padStart(2, '0') %>
                – <%= String(sm.closingHour || 0).padStart(2, '0') %>:<%= String(sm.closingMinute || 0).padStart(2, '0') %>
                <% if (sm.openNow) { %>
                  <span class="badge bg-success">Aberto</span>
                <% } else { %>
                  <span class="badge bg-danger">Fechado</span>
                <% } %>
              </p>
              <% if (sm.averageRating > 0) { %>
                <p class="small mb-1">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <i class="bi <%= i <= Math.round(sm.averageRating) ? 'bi-star-fill text-warning' : 'bi-star text-muted' %>" style="font-size: 0.8rem;"></i>
                  <% } %>
                  <span class="text-muted">(<%= sm.totalRatings || 0 %>)</span>
                </p>
              <% } %>
              <div class="mt-auto pt-2">
                <a href="/customer/supermarkets/<%= sm._id %>" class="btn btn-primary btn-sm w-100">
                  <i class="bi bi-eye"></i> Ver produtos
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <p class="text-muted mt-3"><%= supermarkets.length %> supermercado(s)</p>
  <% } %>
</body>
</html>