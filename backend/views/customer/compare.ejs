<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comparar Preços — <%= productName %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <a href="/customer/products" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Produtos</a>
      <a href="/dashboard" class="btn btn-outline-dark">Dashboard</a>
    </div>
    <a href="/customer/cart" class="btn btn-outline-primary">
      <i class="bi bi-cart3"></i> Carrinho (<%= cartCount %>)
    </a>
  </nav>

  <h1 class="h3 mb-2"><i class="bi bi-bar-chart"></i> Comparar Preços</h1>
  <p class="text-muted mb-4">Produto: <strong>"<%= productName %>"</strong></p>

  <% if (!products || products.length === 0) { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle"></i> Nenhum supermercado tem este produto disponível.
    </div>
  <% } else { %>
    <div class="card shadow-sm mb-4">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th>Produto</th>
              <th>Supermercado</th>
              <th>Localização</th>
              <th>Preço</th>
              <th>Stock</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <% let cheapestPrice = products.length > 0 ? products[0].price : 0; %>
            <% products.forEach((product, index) => { %>
              <tr class="<%= index === 0 ? 'table-success' : '' %>">
                <td>
                  <strong><%= product.name %></strong>
                  <% if (product.category) { %>
                    <br><small class="text-muted"><%= product.category %></small>
                  <% } %>
                </td>
                <td>
                  <% if (product.supermarket) { %>
                    <a href="/customer/supermarkets/<%= product.supermarket._id %>">
                      <i class="bi bi-shop"></i> <%= product.supermarket.name %>
                    </a>
                  <% } else { %>
                    N/A
                  <% } %>
                </td>
                <td>
                  <% if (product.supermarket) { %>
                    <%= product.supermarket.city || '' %>, <%= product.supermarket.district || '' %>
                  <% } %>
                </td>
                <td>
                  <strong class="<%= index === 0 ? 'text-success' : '' %>"><%= product.price.toFixed(2) %> €</strong>
                  <% if (index === 0 && products.length > 1) { %>
                    <br><span class="badge bg-success">Melhor preço</span>
                  <% } %>
                  <% if (index > 0) { %>
                    <br><small class="text-danger">+<%= (product.price - cheapestPrice).toFixed(2) %> €</small>
                  <% } %>
                </td>
                <td><%= product.stock %></td>
                <td>
                  <% if (product.stock > 0) { %>
                    <form method="POST" action="/customer/cart/add" class="d-inline">
                      <input type="hidden" name="productId" value="<%= product._id %>">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-cart-plus"></i> Adicionar
                      </button>
                    </form>
                  <% } else { %>
                    <span class="badge bg-secondary">Sem stock</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (products.length > 1) { %>
      <div class="alert alert-success">
        <i class="bi bi-trophy"></i>
        <strong>Melhor preço:</strong> <%= products[0].price.toFixed(2) %> € em
        <strong><%= products[0].supermarket ? products[0].supermarket.name : 'N/A' %></strong>.
        Poupança máxima: <strong><%= (products[products.length - 1].price - products[0].price).toFixed(2) %> €</strong>
        vs. o preço mais alto.
      </div>
    <% } %>
  <% } %>
</body>
</html>
