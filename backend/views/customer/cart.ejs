<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Carrinho de Compras</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <a href="/customer/products" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Continuar a comprar</a>
      <a href="/dashboard" class="btn btn-outline-dark">Dashboard</a>
    </div>
    <span class="badge bg-primary fs-6"><i class="bi bi-cart3"></i> <%= cartCount %> itens</span>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-cart3"></i> Carrinho de Compras</h1>

  <% if (!cart.items || cart.items.length === 0) { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle"></i> O teu carrinho está vazio.
      <a href="/customer/products" class="alert-link">Explorar produtos</a>
    </div>
  <% } else { %>
    <form id="checkout-form" method="POST" action="/customer/cart/checkout" style="display: none;">
      <% Object.keys(groupedItems).forEach(smId => { %>
        <% const group = groupedItems[smId]; %>
        <% const initialValue = (group.supermarket && group.supermarket.deliveryMethods && !group.supermarket.deliveryMethods.includes('pickup') && group.supermarket.deliveryMethods.includes('courier')) ? 'courier' : 'pickup'; %>
        <input type="hidden" name="deliveryMethod_<%= smId %>" id="hidden_delivery_<%= smId %>" value="<%= initialValue %>">
      <% }) %>
    </form>
      <% const smIds = Object.keys(groupedItems); %>
      <% smIds.forEach(smId => { %>
        <% const group = groupedItems[smId]; %>
        <div class="card shadow-sm mb-4">
          <div class="card-header d-flex justify-content-between align-items-center">
            <strong><i class="bi bi-shop"></i> <%= group.supermarket ? group.supermarket.name : 'Supermercado' %></strong>
            <span class="badge bg-secondary">Subtotal: <%= group.subtotal.toFixed(2) %> €</span>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Produto</th>
                    <th>Preço unitário</th>
                    <th>Quantidade</th>
                    <th>Subtotal</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% group.items.forEach(item => { %>
                    <tr>
                      <td>
                        <strong><%= item.product ? item.product.name : 'Produto removido' %></strong>
                        <% if (item.product && item.product.category) { %>
                          <br><small class="text-muted"><%= item.product.category %></small>
                        <% } %>
                      </td>
                      <td><%= item.product ? item.product.price.toFixed(2) : '0.00' %> €</td>
                      <td style="width: 160px;">
                        <form method="POST" action="/customer/cart/update" class="d-flex gap-1">
                          <input type="hidden" name="productId" value="<%= item.product ? item.product._id : '' %>">
                          <input type="number" name="quantity" value="<%= item.quantity %>" min="1"
                            max="<%= item.product ? item.product.stock : 99 %>" class="form-control form-control-sm" style="width: 70px;">
                          <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-repeat"></i></button>
                        </form>
                      </td>
                      <td><strong><%= item.lineTotal ? item.lineTotal.toFixed(2) : '0.00' %> €</strong></td>
                      <td>
                        <form method="POST" action="/customer/cart/remove" style="display:inline;">
                          <input type="hidden" name="productId" value="<%= item.product ? item.product._id : '' %>">
                          <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <% if (group.supermarket && group.supermarket.deliveryMethods) { %>
              <div class="mt-3 p-3 bg-light rounded">
                <label class="form-label"><strong>Método de entrega:</strong></label>
                <% if (group.supermarket.deliveryMethods.includes('pickup')) { %>
                  <div class="form-check">
                    <input class="form-check-input delivery-radio" type="radio" name="displayDelivery[<%= smId %>]" value="pickup" data-smid="<%= smId %>" id="pickup_<%= smId %>" checked>
                    <label class="form-check-label" for="pickup_<%= smId %>">
                      Levantamento em loja
                      <% if (group.supermarket.pickupCost > 0) { %>
                        (<%= group.supermarket.pickupCost.toFixed(2) %> €)
                      <% } else { %>
                        (Grátis)
                      <% } %>
                    </label>
                  </div>
                <% } %>
                <% if (group.supermarket.deliveryMethods.includes('courier')) { %>
                  <div class="form-check">
                    <input class="form-check-input delivery-radio" type="radio" name="displayDelivery[<%= smId %>]" value="courier" data-smid="<%= smId %>" id="courier_<%= smId %>"
                      <%= !group.supermarket.deliveryMethods.includes('pickup') ? 'checked' : '' %>>
                    <label class="form-check-label" for="courier_<%= smId %>">
                      Entrega por estafeta
                      (<%= (group.supermarket.courierCost || 0).toFixed(2) %> €)
                    </label>
                  </div>
                <% } %>
              </div>
            <% } else { %>
              <input type="hidden" name="displayDelivery[<%= smId %>]" value="pickup">
            <% } %>
          </div>
        </div>
      <% }) %>

      <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
          <h4 class="mb-0">Total dos produtos: <strong><%= total.toFixed(2) %> €</strong></h4>
          <small class="text-muted">(custos de entrega aplicados no checkout)</small>
        </div>
      </div>

      <button type="submit" form="checkout-form" class="btn btn-success btn-lg w-100">
        <i class="bi bi-bag-check"></i> Finalizar Encomenda
      </button>

      <script>
        document.querySelectorAll('.delivery-radio').forEach(radio => {
          radio.addEventListener('change', function() {
            const hiddenInput = document.getElementById('hidden_delivery_' + this.dataset.smid);
            if (hiddenInput) {
              hiddenInput.value = this.value;
            }
          });
        });
      </script>
  <% } %>
</body>
</html>
