<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Vendas</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">

  <nav class="mb-4">
    <a href="/dashboard" class="btn btn-secondary">Dashboard</a>
    <a href="/sales/create" class="btn btn-primary">Nova Venda</a>
  </nav>

  <h1 class="mb-4">Lista de Vendas</h1>

  <form method="GET" action="/sales" class="row g-2 mb-4">
    <div class="col-md-8">
      <input type="text" name="search" class="form-control" placeholder="Pesquisar por nome de produto" value="<%= typeof search !== 'undefined' ? search : '' %>">
    </div>
    <div class="col-md-4">
      <button type="submit" class="btn btn-primary w-100">Pesquisar</button>
    </div>
  </form>

  <% if (!sales || sales.length === 0) { %>
    <div class="alert alert-info">Não existem vendas registadas.</div>
  <% } else { %>
    <% sales.forEach(sale => { %>
      <div class="card mb-3">
        <div class="card-body">
          <h5 class="card-title">Venda #<%= sale.saleNumber %></h5>
          <p><strong>Cliente:</strong> <%= sale.customer?.name || 'Consumidor Final' %></p>
          <p><strong>Total:</strong> <%= Number(sale.total).toFixed(2) %> €</p>
          <p><strong>Estado:</strong> <%= sale.status %></p>

          <h6>Produtos:</h6>
          <ul>
            <% sale.items.forEach(item => { %>
              <li>
                <%= item.name %> - <%= item.quantity %> x <%= Number(item.price).toFixed(2) %> €
              </li>
            <% }) %>
          </ul>

          <% if (sale.status !== 'cancelled') { %>
            <form method="POST" action="/sales/cancel/<%= sale._id %>">
              <button type="submit" class="btn btn-danger btn-sm">Anular venda</button>
            </form>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</body>
</html>