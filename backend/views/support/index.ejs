<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Suporte — <%= user.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="mb-4">
    <a href="/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-headset"></i> Centro de Suporte</h1>

  <div class="row g-4">
    <div class="col-md-5">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white"><strong>Novo Pedido de Suporte</strong></div>
        <div class="card-body">
          <form method="POST" action="/support/create">
            <div class="mb-3">
              <label class="form-label">Motivo / Assunto</label>
              <input type="text" name="subject" class="form-control" placeholder="Ex: Problema com entrega, Erro no pagamento..." required>
            </div>
            <div class="mb-3">
              <label class="form-label">Descrição</label>
              <textarea name="description" class="form-control" rows="5" placeholder="Descreve detalhadamente o problema..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">Enviar Pedido</button>
          </form>
        </div>
      </div>
    </div>

    <div class="col-md-7">
      <h2 class="h5 mb-3">Os Meus Pedidos</h2>
      <% if (!myTickets || myTickets.length === 0) { %>
        <div class="alert alert-info">Ainda não criaste nenhum pedido de suporte.</div>
      <% } else { %>
        <% myTickets.forEach(ticket => { %>
          <div class="card shadow-sm mb-3 border-<%= ticket.status === 'closed' ? 'success' : (ticket.status === 'cancelled' ? 'danger' : 'primary') %>">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title mb-0"><%= ticket.subject %></h5>
                <span class="badge bg-<%= ticket.status === 'closed' ? 'success' : (ticket.status === 'cancelled' ? 'danger' : 'primary') %>">
                  <%= ticket.status.toUpperCase() %>
                </span>
              </div>
              <p class="card-text"><%= ticket.description %></p>
              <small class="text-muted"><%= new Date(ticket.createdAt).toLocaleDateString('pt-PT') %></small>

              <% if (ticket.messages && ticket.messages.length > 0) { %>
                <div class="mt-3">
                  <% ticket.messages.forEach(msg => { %>
                    <div class="p-2 mb-2 rounded <%= msg.sender === 'admin' ? 'bg-light border-start border-4 border-info' : 'bg-primary bg-opacity-10 border-end border-4 border-primary text-end' %>">
                      <small class="fw-bold"><%= msg.sender === 'admin' ? 'Suporte' : 'Eu' %>:</small>
                      <p class="mb-0"><%= msg.text %></p>
                      <small class="text-muted"><%= new Date(msg.createdAt).toLocaleDateString('pt-PT') %></small>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <% if (ticket.status === 'opened') { %>
                <div class="mt-3 p-3 border rounded bg-light">
                  <p class="mb-2"><strong>O problema foi resolvido?</strong></p>
                  <form method="POST" action="/support/<%= ticket._id %>/resolve">
                    <div class="d-flex gap-2 mb-3">
                      <button type="submit" name="resolved" value="yes" class="btn btn-sm btn-success">Sim, fechar ticket</button>
                      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('reply-form-<%= ticket._id %>').classList.toggle('d-none')">Não, ainda preciso de ajuda</button>
                    </div>
                    
                    <div id="reply-form-<%= ticket._id %>" class="d-none">
                      <label class="form-label small">Explica o que ainda falta resolver:</label>
                      <textarea name="userReply" class="form-control mb-2" rows="2"></textarea>
                      <button type="submit" name="resolved" value="no" class="btn btn-sm btn-primary">Enviar Mensagem</button>
                    </div>
                  </form>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>
