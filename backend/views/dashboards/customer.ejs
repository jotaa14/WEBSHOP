<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Cliente</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1"><i class="bi bi-person-circle"></i> Dashboard do Cliente</h1>
      <p class="text-muted mb-0">Bem-vindo, <%= user.name %>.</p>
      <p class="text-muted mb-0">Distrito: <%= user.district %></p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/profile#update-address" class="btn btn-outline-primary"><i class="bi bi-geo-alt"></i> Alterar morada</a>
      <a href="/profile" class="btn btn-outline-warning"><i class="bi bi-key"></i> Alterar password</a>
      <a href="/logout" class="btn btn-outline-danger"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card shadow-sm border-primary">
        <div class="card-body text-center">
          <i class="bi bi-bag fs-2 text-primary"></i>
          <h3 class="mt-2 mb-0"><%= stats.totalOrders %></h3>
          <small class="text-muted">Total encomendas</small>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm border-success">
        <div class="card-body text-center">
          <i class="bi bi-check-circle fs-2 text-success"></i>
          <h3 class="mt-2 mb-0"><%= stats.deliveredOrders %></h3>
          <small class="text-muted">Entregues</small>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm border-warning">
        <div class="card-body text-center">
          <i class="bi bi-hourglass fs-2 text-warning"></i>
          <h3 class="mt-2 mb-0"><%= stats.pendingOrders %></h3>
          <small class="text-muted">Em curso</small>
        </div>
      </div>
    </div>
  </div>

  <% if (stats.topProducts && stats.topProducts.length > 0) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong><i class="bi bi-trophy"></i> Produtos mais comprados</strong></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Produto</th>
                <th>Quantidade</th>
                <th>Total gasto</th>
              </tr>
            </thead>
            <tbody>
              <% stats.topProducts.forEach((p, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= p._id %></td>
                  <td><%= p.totalQuantity %></td>
                  <td><%= p.totalSpent.toFixed(2) %> €</td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Actions -->
  <h2 class="h5 mb-3">Ações</h2>
  <div class="row g-3">
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-shop"></i> Supermercados</h5>
          <p class="text-muted small">Explorar supermercados e os seus produtos.</p>
          <a href="/customer/supermarkets" class="btn btn-primary">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-search"></i> Pesquisar produtos</h5>
          <p class="text-muted small">Pesquisar, filtrar e comparar preços.</p>
          <a href="/customer/products" class="btn btn-info text-white">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-bag"></i> Minhas encomendas</h5>
          <p class="text-muted small">Consultar estado e histórico.</p>
          <a href="/customer/orders" class="btn btn-success">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-cart3"></i> Carrinho</h5>
          <p class="text-muted small">Ver itens no carrinho e finalizar encomenda.</p>
          <a href="/customer/cart" class="btn btn-dark">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100 border-danger">
        <div class="card-body">
          <h5><i class="bi bi-headset"></i> Suporte</h5>
          <p class="text-muted small">Contactar o administrador para ajuda.</p>
          <a href="/support" class="btn btn-danger">Contactar Suporte</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>