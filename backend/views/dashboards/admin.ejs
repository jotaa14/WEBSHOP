<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1"><i class="bi bi-shield-lock"></i> Dashboard do Administrador</h1>
      <p class="text-muted mb-0">Bem-vindo, <%= user.name %>.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/profile" class="btn btn-outline-warning"><i class="bi bi-key"></i> Alterar password</a>
      <a href="/logout" class="btn btn-outline-danger"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm border-primary">
        <div class="card-body text-center">
          <i class="bi bi-people fs-2 text-primary"></i>
          <h3 class="mt-2 mb-0"><%= stats.totalUsers %></h3>
          <small class="text-muted">Total utilizadores</small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm border-success">
        <div class="card-body text-center">
          <i class="bi bi-shop fs-2 text-success"></i>
          <h3 class="mt-2 mb-0"><%= stats.totalSupermarkets %></h3>
          <small class="text-muted">Supermercados ativos</small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm border-info">
        <div class="card-body text-center">
          <i class="bi bi-bag-check fs-2 text-info"></i>
          <h3 class="mt-2 mb-0"><%= stats.totalOrders %></h3>
          <small class="text-muted">Total encomendas</small>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm border-warning">
        <div class="card-body text-center">
          <i class="bi bi-receipt fs-2 text-warning"></i>
          <h3 class="mt-2 mb-0"><%= stats.totalSales %></h3>
          <small class="text-muted">Total vendas (caixa)</small>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <small class="text-muted">Clientes</small>
          <h4><%= stats.totalCustomers %></h4>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <small class="text-muted">Estafetas ativos</small>
          <h4><%= stats.totalCouriers %></h4>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <small class="text-muted">SM pendentes</small>
          <h4 class="<%= stats.pendingSupermarkets > 0 ? 'text-danger' : '' %>"><%= stats.pendingSupermarkets %></h4>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm">
        <div class="card-body text-center">
          <small class="text-muted">Estafetas pendentes</small>
          <h4 class="<%= stats.pendingCouriers > 0 ? 'text-danger' : '' %>"><%= stats.pendingCouriers %></h4>
        </div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <h2 class="h5 mb-3">Ações</h2>
  <div class="row g-3">
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-people"></i> Gerir utilizadores</h5>
          <p class="text-muted">Consultar e administrar os utilizadores da plataforma.</p>
          <a href="/admin/users" class="btn btn-primary">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-shop"></i> Validar supermercados</h5>
          <p class="text-muted">Validar e aprovar os supermercados pendentes.</p>
          <a href="/admin/validate-supermarkets" class="btn btn-success">
            Abrir
            <% if (stats.pendingSupermarkets > 0) { %>
              <span class="badge bg-danger"><%= stats.pendingSupermarkets %></span>
            <% } %>
          </a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-bicycle"></i> Validar estafetas</h5>
          <p class="text-muted">Validar e aprovar os estafetas pendentes.</p>
          <a href="/admin/validate-couriers" class="btn btn-dark">
            Abrir
            <% if (stats.pendingCouriers > 0) { %>
              <span class="badge bg-danger"><%= stats.pendingCouriers %></span>
            <% } %>
          </a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-box-seam"></i> Monitorizar Encomendas</h5>
          <p class="text-muted">Acompanhar todas as encomendas do sistema.</p>
          <a href="/admin/orders" class="btn btn-warning">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-tags"></i> Gerir Categorias</h5>
          <p class="text-muted">Criar e apagar categorias de produtos.</p>
          <a href="/admin/categories" class="btn btn-info">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-chat-left-text"></i> Moderar Avaliações</h5>
          <p class="text-muted">Visualizar e moderar avaliações da plataforma.</p>
          <a href="/admin/courier-reviews" class="btn btn-secondary">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-activity"></i> Movimentos do Site</h5>
          <p class="text-muted">Consultar o log de atividades e movimentos do sistema.</p>
          <a href="/admin/activities" class="btn btn-primary">Abrir Atividades</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100 border-danger">
        <div class="card-body">
          <h5><i class="bi bi-headset"></i> Pedidos de Suporte</h5>
          <p class="text-muted">Responder a pedidos de ajuda de utilizadores.</p>
          <a href="/admin/support-tickets" class="btn btn-danger">Abrir Tickets</a>
        </div>
      </div>
    </div>
  </div>

</body>
</html>