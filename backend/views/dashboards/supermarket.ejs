<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Supermercado</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1"><i class="bi bi-shop"></i> Dashboard do Supermercado</h1>
      <p class="text-muted mb-0">Bem-vindo, <%= user.name %>.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/profile" class="btn btn-outline-warning"><i class="bi bi-key"></i> Mudar password</a>
      <a href="/logout" class="btn btn-outline-danger"><i class="bi bi-box-arrow-right"></i> Terminar sessão</a>
    </div>
  </div>

  <% if (stats) { %>
    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-primary">
          <div class="card-body text-center">
            <i class="bi bi-bag fs-3 text-primary"></i>
            <h4 class="mt-1 mb-0"><%= stats.totalOrders %></h4>
            <small class="text-muted">Encomendas</small>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-warning">
          <div class="card-body text-center">
            <i class="bi bi-hourglass fs-3 text-warning"></i>
            <h4 class="mt-1 mb-0"><%= stats.pendingOrders %></h4>
            <small class="text-muted">Pendentes</small>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-success">
          <div class="card-body text-center">
            <i class="bi bi-check-circle fs-3 text-success"></i>
            <h4 class="mt-1 mb-0"><%= stats.deliveredOrders %></h4>
            <small class="text-muted">Entregues</small>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-info">
          <div class="card-body text-center">
            <i class="bi bi-receipt fs-3 text-info"></i>
            <h4 class="mt-1 mb-0"><%= stats.totalSales %></h4>
            <small class="text-muted">Vendas caixa</small>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-secondary">
          <div class="card-body text-center">
            <i class="bi bi-box-seam fs-3 text-secondary"></i>
            <h4 class="mt-1 mb-0"><%= stats.totalProducts %></h4>
            <small class="text-muted">Produtos</small>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-dark">
          <div class="card-body text-center">
            <i class="bi bi-star fs-3 text-dark"></i>
            <h4 class="mt-1 mb-0"><%= supermarket && supermarket.averageRating ? supermarket.averageRating.toFixed(1) : '0.0' %></h4>
            <small class="text-muted">Avaliação</small>
          </div>
        </div>
      </div>
    </div>

    <% if (stats.topProducts && stats.topProducts.length > 0) { %>
      <div class="card shadow-sm mb-4">
        <div class="card-header"><strong><i class="bi bi-trophy"></i> Produtos mais vendidos</strong></div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Produto</th>
                  <th>Quantidade vendida</th>
                  <th>Receita</th>
                </tr>
              </thead>
              <tbody>
                <% stats.topProducts.forEach((p, i) => { %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td><%= p._id %></td>
                    <td><%= p.totalQuantity %></td>
                    <td><%= p.totalRevenue.toFixed(2) %> €</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>

  <!-- Actions -->
  <h2 class="h5 mb-3">Ações</h2>
  <div class="row g-3">
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-box-seam"></i> Gerir produtos</h5>
          <p class="text-muted small">Consultar, criar, editar e remover produtos.</p>
          <a href="/products" class="btn btn-primary">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-receipt"></i> Registar venda</h5>
          <p class="text-muted small">Vendas e histórico.</p>
          <div class="d-flex gap-2 flex-wrap">
            <a href="/sales/create" class="btn btn-success">Nova venda</a>
            <a href="/sales" class="btn btn-outline-success">Ver vendas</a>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100 border-dark">
        <div class="card-body">
          <h5><i class="bi bi-bag"></i> Gerir encomendas</h5>
          <p class="text-muted small">Encomendas pendentes, confirmadas e em entrega.</p>
          <a href="/supermarket/orders/manage/pending" class="btn btn-dark">Abrir gestão</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-pencil-square"></i> Configurações</h5>
          <p class="text-muted small">Editar dados do supermercado, horário e entregas.</p>
          <a href="/supermarket/edit" class="btn btn-secondary">Editar</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100 border-warning">
        <div class="card-body">
          <h5><i class="bi bi-arrow-return-left"></i> Devoluções</h5>
          <p class="text-muted small">Gerir pedidos de devolução e reclamações de clientes.</p>
          <a href="/supermarket/returns" class="btn btn-warning">Abrir Devoluções</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100 border-info">
        <div class="card-body">
          <h5><i class="bi bi-star"></i> Avaliações</h5>
          <p class="text-muted small">Consultar o feedback e pontuações dos clientes.</p>
          <a href="/supermarket/reviews" class="btn btn-info text-white">Ver Avaliações</a>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card shadow-sm h-100 border-danger">
        <div class="card-body">
          <h5><i class="bi bi-headset"></i> Suporte</h5>
          <p class="text-muted small">Contactar o administrador para ajuda.</p>
          <a href="/support" class="btn btn-danger">Contactar Suporte</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>