<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Estafeta</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1"><i class="bi bi-bicycle"></i> Dashboard do Estafeta</h1>
      <p class="text-muted mb-0">Bem-vindo, <%= user.name %>.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/profile#update-address" class="btn btn-outline-primary"><i class="bi bi-geo-alt"></i> Alterar morada</a>
      <a href="/profile" class="btn btn-outline-warning"><i class="bi bi-key"></i> Alterar password</a>
      <a href="/logout" class="btn btn-outline-danger"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card shadow-sm border-primary">
        <div class="card-body text-center">
          <i class="bi bi-truck fs-2 text-primary"></i>
          <h3 class="mt-2 mb-0"><%= stats.totalDeliveries %></h3>
          <small class="text-muted">Total entregas atribuídas</small>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm border-success">
        <div class="card-body text-center">
          <i class="bi bi-check-circle fs-2 text-success"></i>
          <h3 class="mt-2 mb-0"><%= stats.deliveredCount %></h3>
          <small class="text-muted">Entregas concluídas</small>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm <%= stats.hasActiveDelivery ? 'border-warning' : 'border-secondary' %>">
        <div class="card-body text-center">
          <i class="bi bi-geo-alt fs-2 <%= stats.hasActiveDelivery ? 'text-warning' : 'text-secondary' %>"></i>
          <h3 class="mt-2 mb-0"><%= stats.hasActiveDelivery ? 'Sim' : 'Não' %></h3>
          <small class="text-muted">Entrega ativa</small>
        </div>
      </div>
    </div>
  </div>

  <% if (stats.topSupermarkets && stats.topSupermarkets.length > 0) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong><i class="bi bi-trophy"></i> Supermercados com mais entregas</strong></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Supermercado</th>
                <th>Entregas</th>
              </tr>
            </thead>
            <tbody>
              <% stats.topSupermarkets.forEach((s, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= s.supermarket ? s.supermarket.name : 'N/A' %></td>
                  <td><%= s.count %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Actions -->
  <h2 class="h5 mb-3">Ações</h2>
  <div class="row g-3">
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-geo-alt"></i> Entregas disponíveis</h5>
          <p class="text-muted">Ver encomendas em preparação no teu distrito e aceitá-las.</p>
          <a href="/courier/available-orders" class="btn btn-primary">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-truck"></i> Entregas em andamento</h5>
          <p class="text-muted">Consultar entregas atribuídas e marcar como entregues.</p>
          <a href="/courier/my-deliveries" class="btn btn-success">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5><i class="bi bi-star"></i> Avaliações</h5>
          <p class="text-muted">Consultar avaliações e opiniões deixadas pelos clientes.</p>
          <a href="/courier/reviews" class="btn btn-dark">Abrir</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-sm h-100 border-danger">
        <div class="card-body">
          <h5><i class="bi bi-headset"></i> Suporte</h5>
          <p class="text-muted small">Contactar o administrador para ajuda.</p>
          <a href="/support" class="btn btn-danger">Contactar Suporte</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>