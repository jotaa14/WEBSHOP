<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entregas em Andamento</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Entregas do Estafeta</h1>
      <p class="text-muted mb-0">Aqui vês as tuas entregas em andamento e histórico.</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/courier/available-orders" class="btn btn-outline-primary">Ver disponíveis</a>
      <a href="/courier/reviews" class="btn btn-outline-dark">Ver avaliações</a>
      <a href="/dashboard" class="btn btn-outline-secondary">Voltar à dashboard</a>
    </div>
  </div>

  <% if (!orders || orders.length === 0) { %>
    <div class="alert alert-info">Ainda não tens entregas associadas.</div>
  <% } else { %>
    <% orders.forEach(order => { %>
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h2 class="h5 mb-1">Encomenda #<%= order._id %></h2>
              <p class="text-muted mb-0">Estado atual: <strong><%= order.status %></strong></p>
            </div>
            <% if (order.status === 'delivered') { %>
              <span class="badge text-bg-success">Entregue</span>
            <% } else if (order.status === 'delivering') { %>
              <span class="badge text-bg-primary">Em entrega</span>
            <% } else { %>
              <span class="badge text-bg-info">A aguardar entrega do supermercado</span>
            <% } %>
          </div>

          <p class="mb-2"><strong>Supermercado:</strong> <%= order.supermarket?.name || 'N/I' %></p>
          <p class="mb-2"><strong>Cliente:</strong> <%= order.customer?.name || 'N/I' %></p>
          <p class="mb-2"><strong>Morada do cliente:</strong> <%= order.customer?.address || 'N/I' %></p>
          <p class="mb-2"><strong>Contacto do cliente:</strong> <%= order.customer?.phone || 'N/I' %></p>
          <p class="mb-3"><strong>Total:</strong> <%= Number(order.total).toFixed(2) %> €</p>

          <ul class="list-group mb-3">
            <% order.items.forEach(item => { %>
              <li class="list-group-item d-flex justify-content-between">
                <span><%= item.name %> x <%= item.quantity %></span>
                <span><%= Number(item.subtotal).toFixed(2) %> €</span>
              </li>
            <% }) %>
          </ul>

          <% if (order.status === 'delivering') { %>
            <form method="POST" action="/courier/orders/<%= order._id %>/delivered">
              <button type="submit" class="btn btn-success">Validar como entregue</button>
            </form>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</body>
</html>