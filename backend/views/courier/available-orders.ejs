<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entregas Disponíveis</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Entregas Disponíveis</h1>
      <p class="text-muted mb-0">Só aparecem encomendas em preparação do teu distrito.</p>
    </div>
    <a href="/dashboard" class="btn btn-outline-secondary">Voltar à dashboard</a>
  </div>

  <% if (!orders || orders.length === 0) { %>
    <div class="alert alert-info">Não existem entregas disponíveis neste momento.</div>
  <% } else { %>
    <% orders.forEach(order => { %>
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h2 class="h5 mb-3">Encomenda #<%= order._id %></h2>
          <p class="mb-2"><strong>Supermercado:</strong> <%= order.supermarket?.name || 'N/I' %></p>
          <p class="mb-2"><strong>Cliente:</strong> <%= order.customer?.name || 'N/I' %></p>
          <p class="mb-2"><strong>Morada do cliente:</strong> <%= order.customer?.address || 'N/I' %></p>
          <p class="mb-2"><strong>Contacto do cliente:</strong> <%= order.customer?.phone || 'N/I' %></p>
          <p class="mb-2"><strong>Distrito:</strong> <%= order.deliveryDistrict %></p>
          <p class="mb-3"><strong>Total:</strong> <%= Number(order.total).toFixed(2) %> €</p>

          <ul class="list-group mb-3">
            <% order.items.forEach(item => { %>
              <li class="list-group-item d-flex justify-content-between">
                <span><%= item.name %> x <%= item.quantity %></span>
                <span><%= Number(item.subtotal).toFixed(2) %> €</span>
              </li>
            <% }) %>
          </ul>

          <form method="POST" action="/courier/orders/<%= order._id %>/accept">
            <button type="submit" class="btn btn-primary">Aceitar entrega</button>
          </form>
        </div>
      </div>
    <% }) %>
  <% } %>
</body>
</html>