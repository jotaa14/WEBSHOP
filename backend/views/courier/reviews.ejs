<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Avaliações do Estafeta</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Avaliações Recebidas</h1>
      <p class="text-muted mb-0">Opiniões dos clientes sobre as tuas entregas.</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/courier/my-deliveries" class="btn btn-outline-primary">Voltar às entregas</a>
      <a href="/dashboard" class="btn btn-outline-secondary">Dashboard</a>
    </div>
  </div>

  <% if (!reviewedOrders || reviewedOrders.length === 0) { %>
    <div class="alert alert-info">Ainda não recebeste avaliações.</div>
  <% } else { %>
    <% reviewedOrders.forEach(order => { %>
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h2 class="h5 mb-2">Encomenda #<%= order._id %></h2>
          <p class="mb-2"><strong>Cliente:</strong> <%= order.customer?.name || 'N/I' %></p>
          <p class="mb-2"><strong>Classificação:</strong> <%= order.courierReview?.rating %>/5</p>
          <p class="mb-0"><strong>Comentário:</strong> <%= order.courierReview?.comment || 'Sem comentário.' %></p>
        </div>
      </div>
    <% }) %>
  <% } %>
</body>
</html>