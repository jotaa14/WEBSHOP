<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .step-section { display: none; }
    .step-section.active { display: block; }
  </style>
</head>
<body class="container mt-4 mb-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-header">
          <h3 class="mb-0">Registar Novo Utilizador</h3>
        </div>
        <div class="card-body">
          <form method="POST" action="/register">
            <input type="hidden" name="role" id="roleHidden">

            <div id="stepRole" class="step-section active">
              <div class="mb-3">
                <label for="roleSelect" class="form-label">Tipo de utilizador</label>
                <select id="roleSelect" class="form-select" required>
                  <option value="">Selecione</option>
                  <option value="customer">Cliente</option>
                  <option value="supermarket">Supermercado</option>
                  <option value="courier">Estafeta</option>
                </select>
              </div>
              <button type="button" class="btn btn-primary" onclick="goRole()">Continuar</button>
            </div>

            <div id="step1Common" class="step-section">
              <div id="personFields">
                <div class="mb-3">
                  <label class="form-label">Nome</label>
                  <input type="text" name="name" class="form-control">
                </div>

                <div class="mb-3">
                  <label class="form-label">Data de nascimento</label>
                  <div class="row g-2">
                    <div class="col-md-4">
                      <select name="birthDay" class="form-select">
                        <option value="">DD</option>
                        <% for (let d = 1; d <= 31; d++) { %>
                          <option value="<%= String(d).padStart(2, '0') %>"><%= String(d).padStart(2, '0') %></option>
                        <% } %>
                      </select>
                    </div>
                    <div class="col-md-4">
                      <select name="birthMonth" class="form-select">
                        <option value="">MM</option>
                        <% for (let m = 1; m <= 12; m++) { %>
                          <option value="<%= String(m).padStart(2, '0') %>"><%= String(m).padStart(2, '0') %></option>
                        <% } %>
                      </select>
                    </div>
                    <div class="col-md-4">
                      <select name="birthYear" class="form-select">
                        <option value="">AAAA</option>
                        <% for (let y = 2026; y >= 1920; y--) { %>
                          <option value="<%= y %>"><%= y %></option>
                        <% } %>
                      </select>
                    </div>
                  </div>
                </div>
              </div>

              <div id="supermarketFields" style="display:none;">
                <div class="mb-3">
                  <label class="form-label">Nome do supermercado</label>
                  <input type="text" name="supermarketName" class="form-control">
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label">NIF</label>
                <input type="text" name="nif" class="form-control" maxlength="9">
              </div>

              <div class="mb-3">
                <label class="form-label">Número de telefone</label>
                <input type="text" name="phone" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" minlength="8">
              </div>

              <div class="mb-3">
                <label class="form-label">Confirmação Password</label>
                <input type="password" name="confirmPassword" class="form-control" minlength="8">
              </div>

              <button type="button" class="btn btn-secondary" onclick="showStep('stepRole')">Voltar</button>
              <button type="button" class="btn btn-primary" onclick="goSecondStep()">Continuar</button>
            </div>

            <div id="step2Customer" class="step-section">
              <div class="mb-3">
                <label class="form-label">Morada do cliente (Rua e número da porta)</label>
                <input type="text" name="customerAddress" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Localidade</label>
                <input type="text" name="customerCity" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Distrito</label>
                <select name="customerDistrict" class="form-select">
                  <option value="">Selecione</option>
                  <% districts.forEach(district => { %>
                    <option value="<%= district %>"><%= district %></option>
                  <% }) %>
                </select>
              </div>

              <button type="button" class="btn btn-secondary" onclick="showStep('step1Common')">Voltar</button>
              <button type="submit" class="btn btn-success">Registar</button>
            </div>

            <div id="step2Courier" class="step-section">
              <div class="mb-3">
                <label class="form-label">Tipo de Veículo</label>
                <select name="vehicleType" class="form-select">
                  <option value="">Selecione</option>
                  <option value="carro">Carro</option>
                  <option value="mota">Mota</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Marca do Veículo</label>
                <input type="text" name="vehicleBrand" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Matrícula do Veículo</label>
                <input type="text" name="vehiclePlate" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Morada do estafeta (Rua e número da porta)</label>
                <input type="text" name="courierAddress" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Localidade</label>
                <input type="text" name="courierCity" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Distrito</label>
                <select name="courierDistrict" class="form-select">
                  <option value="">Selecione</option>
                  <% districts.forEach(district => { %>
                    <option value="<%= district %>"><%= district %></option>
                  <% }) %>
                </select>
              </div>

              <button type="button" class="btn btn-secondary" onclick="showStep('step1Common')">Voltar</button>
              <button type="submit" class="btn btn-success">Registar</button>
            </div>

            <div id="step2Supermarket" class="step-section">
              <div class="mb-3">
                <label class="form-label">Morada do supermercado (Rua e número da porta)</label>
                <input type="text" name="supermarketAddress" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Localidade</label>
                <input type="text" name="supermarketCity" class="form-control">
              </div>

              <div class="mb-3">
                <label class="form-label">Distrito</label>
                <select name="supermarketDistrict" class="form-select">
                  <option value="">Selecione</option>
                  <% districts.forEach(district => { %>
                    <option value="<%= district %>"><%= district %></option>
                  <% }) %>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label">Custo de envio</label>
                <input type="number" step="0.01" min="0" name="courierCost" class="form-control">
              </div>

              <button type="button" class="btn btn-secondary" onclick="showStep('step1Common')">Voltar</button>
              <button type="submit" class="btn btn-success">Registar</button>
            </div>
          </form>

          <div class="mt-3 text-center">
            <a href="/login">Já tens conta? Faz login</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function showStep(stepId) {
      document.querySelectorAll('.step-section').forEach(section => {
        section.classList.remove('active');
      });

      const target = document.getElementById(stepId);
      if (target) {
        target.classList.add('active');
      }
    }

    function goRole() {
      const roleSelect = document.getElementById('roleSelect');
      const roleHidden = document.getElementById('roleHidden');

      if (!roleSelect || !roleHidden) {
        alert('Erro no formulário: campo de perfil não encontrado.');
        return;
      }

      const role = roleSelect.value;

      if (!role) {
        alert('Seleciona o tipo de utilizador.');
        return;
      }

      roleHidden.value = role;

      if (role === 'supermarket') {
        document.getElementById('personFields').style.display = 'none';
        document.getElementById('supermarketFields').style.display = 'block';
      } else {
        document.getElementById('personFields').style.display = 'block';
        document.getElementById('supermarketFields').style.display = 'none';
      }

      showStep('step1Common');
    }

    function goSecondStep() {
      const role = document.getElementById('roleHidden').value;

      if (role === 'customer') {
        showStep('step2Customer');
        return;
      }

      if (role === 'courier') {
        showStep('step2Courier');
        return;
      }

      if (role === 'supermarket') {
        showStep('step2Supermarket');
        return;
      }

      alert('Tipo de utilizador inválido.');
    }

    document.addEventListener('DOMContentLoaded', () => {
      showStep('stepRole');
    });
  </script>
</body>
</html>