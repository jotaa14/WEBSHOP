<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acesso Restrito — Marketplace</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }
    .denied-card {
      background: rgba(30, 41, 59, 0.95);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 1.25rem;
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
      max-width: 460px;
      width: 100%;
      padding: 3rem 2.5rem;
      text-align: center;
      color: #f8fafc;
    }
    .denied-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: rgba(239, 68, 68, 0.12);
      border: 2px solid rgba(239, 68, 68, 0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      font-size: 2rem;
      color: #f87171;
    }
    .denied-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: #f8fafc;
    }
    .denied-text {
      color: #94a3b8;
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 2rem;
    }
    .denied-text strong {
      color: #e2e8f0;
    }
    .btn-go-app {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1.75rem;
      border-radius: 9999px;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      background: linear-gradient(135deg, #6366f1, #06b6d4);
      color: #fff;
      border: none;
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(99, 102, 241, 0.35);
    }
    .btn-go-app:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(99, 102, 241, 0.5);
      color: #fff;
    }
    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.65rem 1.5rem;
      border-radius: 9999px;
      font-weight: 500;
      font-size: 0.875rem;
      text-decoration: none;
      background: transparent;
      color: #94a3b8;
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.3s ease;
      margin-top: 0.75rem;
    }
    .btn-back:hover {
      color: #e2e8f0;
      border-color: rgba(255, 255, 255, 0.25);
      background: rgba(255, 255, 255, 0.05);
    }
    .divider {
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, #6366f1, #06b6d4);
      border-radius: 2px;
      margin: 0 auto 1.5rem;
    }
    .auto-redirect {
      font-size: 0.78rem;
      color: #64748b;
      margin-top: 1.5rem;
    }
  </style>
</head>
<body>
  <div class="denied-card">
    <div class="denied-icon">
      <i class="bi bi-shield-lock"></i>
    </div>
    <h1 class="denied-title"><%= title %></h1>
    <div class="divider"></div>
    <p class="denied-text"><%= message %></p>

    <div class="d-flex flex-column align-items-center">
      <a href="<%= redirectUrl %>" class="btn-go-app">
        <i class="bi bi-box-arrow-up-right"></i>
        <%= buttonText %>
      </a>
      <a href="/login" class="btn-back">
        <i class="bi bi-arrow-left"></i>
        Voltar ao login
      </a>
    </div>

    <p class="auto-redirect">Serás redirecionado automaticamente em <span id="countdown">8</span> segundos...</p>
  </div>

  <script>
    const redirectUrl = '<%= redirectUrl %>';
    let seconds = 8;
    const el = document.getElementById('countdown');
    const timer = setInterval(() => {
      seconds--;
      el.textContent = seconds;
      if (seconds <= 0) {
        clearInterval(timer);
        window.location.href = redirectUrl;
      }
    }, 1000);
  </script>
</body>
</html>
