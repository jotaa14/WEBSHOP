<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gerir Utilizadores — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="mb-4">
    <a href="/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-people"></i> Gerir Utilizadores</h1>
    <span class="badge bg-primary"><%= users.length %> Utilizadores</span>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nome</th>
              <th>Email</th>
              <th>Cargo</th>
              <th>Estado</th>
              <th class="text-end">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td><strong><%= user.name %></strong></td>
                <td><%= user.email %></td>
                <td>
                  <% const roleColors = { admin: 'danger', supermarket: 'success', courier: 'info', customer: 'primary' }; %>
                  <span class="badge bg-<%= roleColors[user.role] || 'secondary' %> text-uppercase small"><%= user.role %></span>
                </td>
                <td>
                  <% if (user.approved) { %>
                    <span class="text-success"><i class="bi bi-check-circle-fill"></i> Aprovado</span>
                  <% } else { %>
                    <span class="text-warning"><i class="bi bi-hourglass-split"></i> Pendente</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <% if (currentUser.id !== user._id.toString()) { %>
                    <form action="/admin/users/delete/<%= user._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Tens a certeza que queres apagar este perfil?')" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Apagar Utilizador">
                          <i class="bi bi-trash"></i>
                        </button>
                    </form>
                  <% } else { %>
                    <span class="badge bg-light text-dark border">Tu</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <% if (users.length === 0) { %>
    <div class="alert alert-info mt-4">Não existem utilizadores registados.</div>
  <% } %>
</body>
</html>