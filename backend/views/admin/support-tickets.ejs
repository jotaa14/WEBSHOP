<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestão de Suporte — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="mb-4">
    <a href="/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-headset"></i> Pedidos de Suporte</h1>

  <% if (!tickets || tickets.length === 0) { %>
    <div class="alert alert-info">Não existem pedidos de suporte pendentes.</div>
  <% } else { %>
    <div class="row g-3">
      <% tickets.forEach(ticket => { %>
        <div class="col-12">
          <div class="card shadow-sm border-<%= ticket.status === 'closed' ? 'success' : (ticket.status === 'cancelled' ? 'danger' : 'primary') %>">
            <div class="card-header d-flex justify-content-between align-items-center">
              <div>
                <strong><%= ticket.userName %></strong> 
                <span class="badge bg-secondary ms-1"><%= ticket.userRole %></span>
                <small class="text-muted ms-2"><%= ticket.userEmail %></small>
              </div>
              <span class="badge bg-<%= ticket.status === 'closed' ? 'success' : (ticket.status === 'cancelled' ? 'danger' : 'primary') %>">
                <%= ticket.status.toUpperCase() %>
              </span>
            </div>
            <div class="card-body">
              <h5 class="card-title"><%= ticket.subject %></h5>
              <p class="card-text"><%= ticket.description %></p>
              <small class="text-muted">Enviado em: <%= new Date(ticket.createdAt).toLocaleString('pt-PT') %></small>

              <% if (ticket.messages && ticket.messages.length > 0) { %>
                <div class="mt-3">
                  <% ticket.messages.forEach(msg => { %>
                    <div class="p-2 mb-2 rounded <%= msg.sender === 'admin' ? 'bg-primary bg-opacity-10 border-end border-4 border-primary text-end' : 'bg-light border-start border-4 border-info' %>">
                      <small class="fw-bold"><%= msg.sender === 'admin' ? 'Eu (Admin)' : 'Utilizador' %>:</small>
                      <p class="mb-0"><%= msg.text %></p>
                      <small class="text-muted"><%= new Date(msg.createdAt).toLocaleString('pt-PT') %></small>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <% if (ticket.status === 'opened') { %>
                <hr>
                <div class="row g-3">
                  <div class="col-md-9">
                    <form method="POST" action="/admin/support-tickets/<%= ticket._id %>/reply" class="d-flex gap-2">
                      <input type="text" name="adminReply" class="form-control" placeholder="Escreve uma resposta..." required>
                      <button type="submit" class="btn btn-primary">Responder</button>
                    </form>
                  </div>
                  <div class="col-md-3 text-end">
                    <form method="POST" action="/admin/support-tickets/<%= ticket._id %>/cancel">
                      <button type="submit" class="btn btn-outline-danger w-100">Cancelar Ticket</button>
                    </form>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</body>
</html>
