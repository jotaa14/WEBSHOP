<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Movimentos do Site — Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="mb-4">
    <a href="/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-activity"></i> Movimentos e Atividades do Site</h1>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/admin/activities" class="row g-2 align-items-end">
        <div class="col-md-5">
          <label class="form-label">Email do Utilizador</label>
          <input type="text" name="email" class="form-control" value="<%= filters.email || '' %>" placeholder="Pesquisar por email...">
        </div>
        <div class="col-md-5">
          <label class="form-label">Tipo de Ação</label>
          <select name="action" class="form-select">
            <option value="">Todas</option>
            <% actions.forEach(act => { %>
              <option value="<%= act %>" <%= filters.action === act ? 'selected' : '' %>><%= act %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2 d-grid">
          <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Filtrar</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Data/Hora</th>
              <th>Utilizador</th>
              <th>Ação</th>
              <th>Detalhes</th>
            </tr>
          </thead>
          <tbody>
            <% if (activities.length === 0) { %>
              <tr>
                <td colspan="4" class="text-center py-4 text-muted">Nenhuma atividade encontrada.</td>
              </tr>
            <% } else { %>
              <% activities.forEach(log => { %>
                <tr>
                  <td>
                    <small class="text-muted"><%= new Date(log.createdAt).toLocaleDateString('pt-PT') %></small><br>
                    <strong><%= new Date(log.createdAt).toLocaleTimeString('pt-PT') %></strong>
                  </td>
                  <td>
                    <strong><%= log.userName %></strong><br>
                    <small class="text-muted"><%= log.userEmail %></small>
                  </td>
                  <td>
                    <% 
                      const actionColors = {
                        PRODUCT_CREATE: 'success',
                        PRODUCT_UPDATE: 'info',
                        PRODUCT_DELETE: 'danger',
                        SALE_REGISTER: 'primary',
                        SALE_CANCEL: 'warning',
                        PURCHASE: 'success',
                        ORDER_CANCEL: 'danger',
                        ORDER_ACCEPT: 'info',
                        RETURN_PROCESS: 'dark',
                        RETURN_DIRECT: 'secondary',
                        DELIVERY_ACCEPT: 'info',
                        DELIVERY_COMPLETE: 'success'
                      };
                    %>
                    <span class="badge bg-<%= actionColors[log.action] || 'secondary' %>"><%= log.action %></span>
                  </td>
                  <td>
                    <%= log.details %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>
