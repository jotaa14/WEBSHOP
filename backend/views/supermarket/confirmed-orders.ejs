<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Encomendas Confirmadas</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Encomendas confirmadas</h1>
      <p class="text-muted mb-0">Inclui estados confirmed e preparing.</p>
    </div>
    <a href="/dashboard" class="btn btn-outline-secondary">Voltar</a>
  </div>

  <% if (!orders || orders.length === 0) { %>
    <div class="alert alert-info">Não existem encomendas confirmadas.</div>
  <% } else { %>
    <div class="row g-3">
      <% orders.forEach(order => { %>
        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                  <h2 class="h5 mb-2">Encomenda #<%= order._id %></h2>
                  <p class="mb-1"><strong>Cliente:</strong> <%= order.customer ? order.customer.name : 'Sem cliente' %></p>
                  <p class="mb-1"><strong>Total:</strong> <%= order.totalPrice ?? 0 %> €</p>
                  <p class="mb-1"><strong>Estado:</strong> <span class="badge bg-success"><%= order.status %></span></p>
                  <p class="mb-0"><strong>Estafeta:</strong> <%= order.courier ? order.courier.name : 'Ainda sem estafeta' %></p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                  <% if (order.status === 'confirmed') { %>
                    <form action="/supermarket/orders/<%= order._id %>/preparing" method="POST">
                      <button type="submit" class="btn btn-primary">Colocar em preparação</button>
                    </form>
                  <% } %>

                  <% if (order.status === 'preparing') { %>
                    <form action="/supermarket/orders/<%= order._id %>/hand-to-courier" method="POST">
                      <button type="submit" class="btn btn-warning">Entregar ao estafeta</button>
                    </form>
                  <% } %>

                  <form action="/supermarket/orders/<%= order._id %>/cancel/confirmed" method="POST">
                    <button type="submit" class="btn btn-danger">Cancelar</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</body>
</html>