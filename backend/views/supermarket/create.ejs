<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Criar Supermercado</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <nav class="mb-4">
    <a href="/dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
  </nav>

  <h1 class="h3 mb-4"><i class="bi bi-shop"></i> Configurar Supermercado</h1>

  <form method="POST" action="/supermarket/create">
    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong>Informações gerais</strong></div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label">Nome do supermercado *</label>
          <input type="text" name="name" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Descrição</label>
          <textarea name="description" class="form-control" rows="3" placeholder="Descrição do supermercado"></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label">Morada (localização) *</label>
          <input type="text" name="location" class="form-control" required>
        </div>

        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Cidade *</label>
            <input type="text" name="city" class="form-control" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Distrito *</label>
            <select name="district" class="form-select" required>
              <option value="">Selecione</option>
              <% districts.forEach(d => { %>
                <option value="<%= d %>"><%= d %></option>
              <% }) %>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong>Horário de funcionamento</strong></div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label">Hora de abertura</label>
            <select name="openingHour" class="form-select">
              <% for (let h = 0; h <= 23; h++) { %>
                <option value="<%= h %>" <%= h === 9 ? 'selected' : '' %>><%= String(h).padStart(2, '0') %></option>
              <% } %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">Minutos abertura</label>
            <select name="openingMinute" class="form-select">
              <option value="0" selected>00</option>
              <option value="15">15</option>
              <option value="30">30</option>
              <option value="45">45</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">Hora de fecho</label>
            <select name="closingHour" class="form-select">
              <% for (let h = 0; h <= 23; h++) { %>
                <option value="<%= h %>" <%= h === 21 ? 'selected' : '' %>><%= String(h).padStart(2, '0') %></option>
              <% } %>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">Minutos fecho</label>
            <select name="closingMinute" class="form-select">
              <option value="0" selected>00</option>
              <option value="15">15</option>
              <option value="30">30</option>
              <option value="45">45</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong>Métodos de entrega e custos</strong></div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label">Métodos de entrega disponíveis</label>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="deliveryMethods" value="pickup" id="methodPickup" checked>
            <label class="form-check-label" for="methodPickup">Levantamento em loja</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="deliveryMethods" value="courier" id="methodCourier">
            <label class="form-check-label" for="methodCourier">Entrega por estafeta</label>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Custo de levantamento em loja (€)</label>
            <input type="number" step="0.01" min="0" name="pickupCost" class="form-control" value="0">
          </div>
          <div class="col-md-6">
            <label class="form-label">Custo de entrega por estafeta (€)</label>
            <input type="number" step="0.01" min="0" name="courierCost" class="form-control" value="0">
          </div>
        </div>
      </div>
    </div>

    <button type="submit" class="btn btn-success btn-lg"><i class="bi bi-check-lg"></i> Criar Supermercado</button>
  </form>
</body>
</html>
