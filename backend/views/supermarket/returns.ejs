<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gerir Devoluções e Reclamações</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Devoluções e Reclamações</h1>
      <p class="text-muted mb-0"><%= supermarket.name %></p>
    </div>
    <a href="/dashboard" class="btn btn-outline-secondary">Voltar à dashboard</a>
  </div>

  <div class="d-flex gap-2 flex-wrap mb-4">
    <a href="/supermarket/returns?tab=pending" class="btn <%= activeTab === 'pending' ? 'btn-warning' : 'btn-outline-warning' %>">Pendentes</a>
    <a href="/supermarket/returns?tab=approved" class="btn <%= activeTab === 'approved' ? 'btn-success' : 'btn-outline-success' %>">Aprovadas / Concluídas</a>
    <a href="/supermarket/returns?tab=rejected" class="btn <%= activeTab === 'rejected' ? 'btn-danger' : 'btn-outline-danger' %>">Rejeitadas</a>
  </div>

  <% 
    const filteredReturns = returns.filter(r => r.status === activeTab);
  %>

  <% if (filteredReturns.length === 0) { %>
    <div class="alert alert-info">Não foram encontrados pedidos de devolução para este estado.</div>
  <% } else { %>
    <div class="d-flex flex-column gap-3 mb-5">
      <% filteredReturns.forEach(req => { %>
        <div class="card shadow-sm">
          <div class="card-header d-flex justify-content-between">
            <strong>ID Encomenda: <span class="text-muted"><%= req.order ? req.order._id : 'N/A' %></span></strong>
            <small class="text-muted"><%= new Date(req.createdAt).toLocaleString('pt-PT') %></small>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-6">
                <p class="mb-1"><strong>Cliente:</strong> <%= req.customer ? req.customer.name : 'N/A' %></p>
                <p class="mb-1"><strong>Produto:</strong> <%= req.product ? req.product.name : 'N/A' %></p>
                <p class="mb-1"><strong>Quantidade:</strong> <%= req.quantity %></p>
                <p class="mb-1"><strong>Condição:</strong> 
                  <% if (req.condition === 'good') { %>
                    <span class="badge bg-success">Em bom estado</span> (Repõe stock)
                  <% } else { %>
                    <span class="badge bg-danger">Danificado/Avariado</span> (Não repõe stock)
                  <% } %>
                </p>
                <p class="mb-0"><strong>Origem do pedido:</strong> <%= req.requestedBy === 'customer' ? 'Cliente' : 'Supermercado' %></p>
              </div>
              <div class="col-md-6 d-flex flex-column justify-content-center align-items-end">
                <% if (activeTab === 'pending') { %>
                  <div class="d-flex gap-2 mt-3 mt-md-0">
                    <form method="POST" action="/supermarket/returns/<%= req._id %>/process">
                      <input type="hidden" name="action" value="approve">
                      <button type="submit" class="btn btn-success" onclick="return confirm('Aprovar este pedido? Se estiver em bom estado o stock será reposto.')">Aprovar</button>
                    </form>
                    <form method="POST" action="/supermarket/returns/<%= req._id %>/process">
                      <input type="hidden" name="action" value="reject">
                      <button type="submit" class="btn btn-danger" onclick="return confirm('Rejeitar este pedido?')">Rejeitar</button>
                    </form>
                  </div>
                <% } else { %>
                  <span class="badge fs-6 bg-<%= req.status === 'approved' ? 'success' : 'danger' %>">
                    <%= req.status === 'approved' ? 'Aprovada' : 'Rejeitada' %>
                  </span>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <hr class="my-5">

  <h3 class="mb-3">Criar Devolução Direta</h3>
  <div class="card shadow-sm">
    <div class="card-body">
      <form method="POST" action="/supermarket/returns/create">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">ID da Encomenda</label>
            <input type="text" name="orderId" class="form-control" required placeholder="Ex: 6624f...">
          </div>
          <div class="col-md-6">
            <label class="form-label">Produto</label>
            <select name="productId" class="form-select" required>
              <option value="" disabled selected>Selecionar artigo do seu supermercado...</option>
              <% products.forEach(p => { %>
                <option value="<%= p._id %>"><%= p.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">Quantidade a devolver da encomenda</label>
            <input type="number" name="quantity" class="form-control" min="1" value="1" required>
          </div>
          <div class="col-md-4">
            <label class="form-label">Condição</label>
            <select name="condition" class="form-select" required>
              <option value="good">Em bom estado (Repõe stock)</option>
              <option value="damaged">Danificado/Avariado (Não repõe stock)</option>
            </select>
          </div>
          <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Criar Devolução</button>
          </div>
        </div>
      </form>
    </div>
  </div>

</body>
</html>
