<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Encomendas em Andamento</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Encomendas em Andamento</h1>
      <p class="text-muted mb-0">Estados: confirmada, em preparação, em entrega</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/supermarket/orders/pending" class="btn btn-outline-primary">Encomendas pendentes</a>
      <a href="/dashboard" class="btn btn-outline-secondary">Voltar à dashboard</a>
    </div>
  </div>

  <% if (!orders || orders.length === 0) { %>
    <div class="alert alert-info">Não existem encomendas em andamento.</div>
  <% } else { %>
    <% orders.forEach(order => { %>
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h2 class="h5 mb-1">Encomenda #<%= order._id %></h2>
              <p class="text-muted mb-0">Estado atual: <strong><%= order.status %></strong></p>
            </div>
            <% if (order.status === 'confirmed') { %>
              <span class="badge text-bg-warning">Confirmada</span>
            <% } else if (order.status === 'preparing') { %>
              <span class="badge text-bg-info">Em preparação</span>
            <% } else { %>
              <span class="badge text-bg-primary">Em entrega</span>
            <% } %>
          </div>

          <p class="mb-2"><strong>Cliente:</strong> <%= order.customer?.name || 'N/I' %></p>
          <p class="mb-2"><strong>Morada:</strong> <%= order.customer?.address || 'N/I' %></p>
          <p class="mb-2"><strong>Contacto:</strong> <%= order.customer?.phone || 'N/I' %></p>
          <p class="mb-2"><strong>Total:</strong> <%= Number(order.total).toFixed(2) %> €</p>

          <% if (order.courier) { %>
            <p class="mb-3"><strong>Estafeta que aceitou:</strong> <%= order.courier.name %> - <%= order.courier.phone || 'Sem telefone' %></p>
          <% } else { %>
            <p class="mb-3"><strong>Estafeta:</strong> Ainda nenhum estafeta aceitou esta encomenda.</p>
          <% } %>

          <ul class="list-group mb-3">
            <% order.items.forEach(item => { %>
              <li class="list-group-item d-flex justify-content-between">
                <span><%= item.name %> x <%= item.quantity %></span>
                <span><%= Number(item.subtotal).toFixed(2) %> €</span>
              </li>
            <% }) %>
          </ul>

          <div class="d-flex gap-2 flex-wrap">
            <% if (order.status === 'confirmed') { %>
              <form method="POST" action="/supermarket/orders/<%= order._id %>/preparing">
                <button type="submit" class="btn btn-primary">Passar para em preparação</button>
              </form>
            <% } %>

            <% if (order.status === 'preparing' && order.courier) { %>
              <form method="POST" action="/supermarket/orders/<%= order._id %>/hand-to-courier">
                <button type="submit" class="btn btn-success">Entregar ao estafeta</button>
              </form>
            <% } %>

            <% if (order.status !== 'delivering') { %>
              <form method="POST" action="/supermarket/orders/<%= order._id %>/cancel">
                <button type="submit" class="btn btn-danger">Cancelar</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  <% } %>
</body>
</html>